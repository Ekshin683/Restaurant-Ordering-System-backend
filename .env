# Server Configuration
PORT=5000

# Database Configuration
MONGO_URI=mongodb://localhost:27017/restaurantdatabase

# JWT Secret Key (Change this to a random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Node Environment
NODE_ENV=development

# Frontend URL used in reset-password email links
FRONTEND_URL=http://localhost:3000

# SMTP Configuration (replace with your real credentials)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Bawarchi <no-reply@bawarchi.com>"
