# Server Configuration
PORT=5000

# Database Configuration
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/restaurant?appName=<app-name>

# JWT Secret Key
JWT_SECRET=your-super-secret-jwt-key

# Node Environment
NODE_ENV=development

# Frontend URL used in reset-password email links
FRONTEND_URL=http://localhost:3000

# Allowed frontend origins for CORS (comma-separated in production)
# Example: https://your-frontend.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# SMTP Configuration (example for Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ekshindeep@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Bawarchi <ekshindeep@gmail.com>"
